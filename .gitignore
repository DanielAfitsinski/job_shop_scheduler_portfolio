## .NET / Visual Studio / VS Code gitignore
## Keeps local caches, build artifacts, and machine-specific files out of source control.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build outputs
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
artifacts/

# Logs and diagnostics
[Ll]og/
[Ll]ogs/
*.log

# Visual Studio / VS Code
.vs/
.vscode/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
nunit-*.xml
*.VisualState.xml

# NuGet / package artifacts
*.nupkg
*.snupkg
packages/
!packages/build/

# .NET legacy lock files
project.lock.json
project.fragment.lock.json

# Publish profiles (user/machine specific)
*.pubxml.user

# Files generated by Visual Studio and tooling
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
